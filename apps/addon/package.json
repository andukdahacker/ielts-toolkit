{
  "name": "@ielts-toolkit/addon",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist tsconfig.server.tsbuildinfo tsconfig.sidebar.tsbuildinfo",
    "build:server": "tsc -p tsconfig.server.json && cp appsscript.json dist/",
    "build:sidebar": "vite build && mv dist/index.html dist/sidebar.html",
    "build": "pnpm clean && pnpm build:server && pnpm build:sidebar",
    "typecheck": "tsc -b",
    "lint": "echo 'addon: no lint yet'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ielts-toolkit/shared": "workspace:*",
    "@preact/signals": "1.3.1",
    "preact": "10.25.4"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.9.4",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/preact": "3.2.4",
    "@types/google-apps-script": "1.0.83",
    "jsdom": "25.0.1",
    "typescript": "^5.7.0",
    "vite": "6.0.7",
    "vite-plugin-singlefile": "2.3.3",
    "vitest": "^3.0.0"
  }
}
